PORT=3000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=phi3

# Google Vision OCR (path to your service-account JSON file)
GOOGLE_APPLICATION_CREDENTIALS=./key.json

# Optional Chroma persistence (requires running Chroma server)
# CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=study_assistant

# Retrieval / upload settings
TOP_K=3
MIN_SIMILARITY=0.2
MAX_UPLOAD_MB=25
